# Versioned Trellis assets live next to this file:
# workflow.md, config.yaml, spec/, scripts/, agents/, .version, .template-hashes.json
# Everything below is local/task/runtime state and must stay out of Git.
tasks/
workspace/

# Developer identity (local only)
.developer

# Current task pointer (each dev works on different task)
.current-task

# Session/window scoped runtime state
.runtime/

# Ralph Loop state file
.ralph-state.json

# Agent runtime files
.agents/
.agent-log
.session-id

# Task directory runtime files
.plan-log

# Atomic update temp files
*.tmp

# Update backup directories
.backup-*

# Conflict resolution temp files
*.new

# Python cache
**/__pycache__/
**/*.pyc
